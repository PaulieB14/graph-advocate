# Required
ANTHROPIC_API_KEY=sk-ant-...

# Required for A2A server
ADVOCATE_PUBLIC_URL=https://graphadvocate.com

# The Graph Gateway API key — used to execute live subgraph queries
# Free: 100K queries/month at thegraph.com/studio
GRAPH_API_KEY=

# Legacy gateway key (fallback)
GATEWAY_API_KEY=

# Optional — Token API auth (has fallback but should be set in production)
TOKEN_API_ACCESS_TOKEN=

# Polymarket trader intelligence endpoints (/polymarket/pnl, /screen, /risk, /pnl-quick).
# Auth re-uses the same Pinax JWT as advocate.py — set TOKEN_API_JWT (canonical name).
# polymarket_intel.py also accepts TOKEN_API_ACCESS_TOKEN (legacy) and PINAX_API_KEY (alias).
PINAX_BASE_URL=https://api.pinax.network/v1/polymarket

# Polygon RPC for ghost-fill wallet-type detection (POST /polymarket/risk + /screen).
# Public RPCs without API key: drpc.org, 1rpc.io. Use Alchemy/QuickNode for production.
POLYGON_RPC_URL=https://polygon.drpc.org

# Optional — Fetch.ai Agentverse integration
AGENTVERSE_API_KEY=

# Optional — admin auth for /logs, /quality, /export/* endpoints
# When set, these endpoints require Bearer token or ?token= param
ADMIN_TOKEN=

# Optional — persistence paths (defaults to /data/ on Railway)
LOG_PATH=/data/requests.json
ACTIVITY_DB_PATH=/data/activity.db
RECOMMENDATIONS_DB=/data/recommendations.db
