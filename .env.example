# Required
ANTHROPIC_API_KEY=sk-ant-...

# Required for A2A server
ADVOCATE_PUBLIC_URL=https://graph-advocate-production.up.railway.app

# The Graph Gateway API key — used to execute live subgraph queries
# Free: 100K queries/month at thegraph.com/studio
GRAPH_API_KEY=

# Legacy gateway key (fallback)
GATEWAY_API_KEY=

# Optional — Token API auth (has fallback but should be set in production)
TOKEN_API_ACCESS_TOKEN=

# Optional — Fetch.ai Agentverse integration
AGENTVERSE_API_KEY=

# Optional — persistence paths (defaults to /data/ on Railway)
LOG_PATH=/data/requests.json
ACTIVITY_DB_PATH=/data/activity.db
RECOMMENDATIONS_DB=/data/recommendations.db
